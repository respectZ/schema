			},
			{
				"fileMatch": [
					"resource_pack/textures/terrain_texture.{json,jsonc,json5}",
					"*RP/textures/terrain_texture.{json,jsonc,json5}",
					"RP_*/textures/terrain_texture.{json,jsonc,json5}",
					"*rp/textures/terrain_texture.{json,jsonc,json5}",
					"rp_*/textures/terrain_texture.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/client/terrain_texture/_index.json"
			},
			{
				"fileMatch": [
					"resource_pack/textures/texture_list.{json,jsonc,json5}",
					"*RP/textures/texture_list.{json,jsonc,json5}",
					"RP_*/textures/texture_list.{json,jsonc,json5}",
					"*rp/textures/texture_list.{json,jsonc,json5}",
					"rp_*/textures/texture_list.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/client/texture_list/_index.json"
			}
		]
	}
}
