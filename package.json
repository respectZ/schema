{
	"name": "schema",
	"type": "module",
	"version": "0.0.0",
	"engines": {
		"vscode": "^1.99.0"
	},
	"private": true,
	"devDependencies": {
		"@minecraft/vanilla-data": "^1.26.21",
		"@types/bun": "latest",
		"prettier": "^3.8.3",
		"prettier-plugin-organize-imports": "^4.3.0",
		"tiny-jsonc": "^1.0.2"
	},
	"peerDependencies": {
		"typescript": "^5.0.0"
	},
	"scripts": {
		"fmt": "prettier --write .",
		"create-schema": "bun scripts/schema.ts",
		"generate": "bun scripts/generator/index.ts",
		"prepack": "bun run generate && bun scripts/prepack.ts",
		"compile": "bun scripts/compile.ts"
	},
	"contributes": {
		"jsonValidation": [
			{
				"fileMatch": [
					"behavior_pack/manifest.{json,jsonc,json5}",
					"*BP/manifest.{json,jsonc,json5}",
					"BP_*/manifest.{json,jsonc,json5}",
					"*bp/manifest.{json,jsonc,json5}",
					"bp_*/manifest.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/shared/manifest/_index.json"
			},
			{
				"fileMatch": [
					"resource_pack/animation_controllers/**/*.{json,jsonc,json5}",
					"*RP/animation_controllers/**/*.{json,jsonc,json5}",
					"RP_*/animation_controllers/**/*.{json,jsonc,json5}",
					"*rp/animation_controllers/**/*.{json,jsonc,json5}",
					"rp_*/animation_controllers/**/*.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/client/animation_controller/_index.json"
			},
			{
				"fileMatch": [
					"resource_pack/animations/**/*.{json,jsonc,json5}",
					"*RP/animations/**/*.{json,jsonc,json5}",
					"RP_*/animations/**/*.{json,jsonc,json5}",
					"*rp/animations/**/*.{json,jsonc,json5}",
					"rp_*/animations/**/*.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/client/animation/_index.json"
			},
			{
				"fileMatch": [
					"resource_pack/block_culling/**/*.{json,jsonc,json5}",
					"*RP/block_culling/**/*.{json,jsonc,json5}",
					"RP_*/block_culling/**/*.{json,jsonc,json5}",
					"*rp/block_culling/**/*.{json,jsonc,json5}",
					"rp_*/block_culling/**/*.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/client/block_culling/_index.json"
			},
			{
				"fileMatch": [
					"resource_pack/blocks.{json,jsonc,json5}",
					"*RP/blocks.{json,jsonc,json5}",
					"RP_*/blocks.{json,jsonc,json5}",
					"*rp/blocks.{json,jsonc,json5}",
					"rp_*/blocks.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/client/blocks/_index.json"
			},
			{
				"fileMatch": [
					"resource_pack/entity/**/*.{json,jsonc,json5}",
					"*RP/entity/**/*.{json,jsonc,json5}",
					"RP_*/entity/**/*.{json,jsonc,json5}",
					"*rp/entity/**/*.{json,jsonc,json5}",
					"rp_*/entity/**/*.{json,jsonc,json5}"
				],
				"url": "./schema/bedrock/client/entity/_index.json"
			},
			{
				"fileMatch": [
					"resource_pack/fogs/**/*.{json,jsonc,json5}",
					"*RP/fogs/**/*.{json,jsonc,json5}",
					"RP_*/fogs/**/*.{json,jsonc,json5}",
