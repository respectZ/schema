{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/client/block_culling/1.20.60/_index.json",
	"title": "Block Culling",
	"type": "object",
	"additionalProperties": false,
	"required": ["format_version", "minecraft:block_culling_rules"],
	"properties": {
		"format_version": {
			"enum": ["1.20.60"]
		},
		"minecraft:block_culling_rules": {
			"type": "object",
			"additionalProperties": false,
			"required": ["description", "rules"],
			"properties": {
				"description": {
					"$ref": "#/$defs/description"
				},
				"rules": {
					"type": "array",
					"minItems": 1,
					"items": {
						"$ref": "#/$defs/rule"
					}
				}
			}
		}
	},
	"$defs": {
		"cardinal_direction": {
			"type": "string",
			"enum": ["down", "up", "north", "south", "west", "east"]
		},
		"description": {
			"title": "Description",
			"type": "object",
			"additionalProperties": false,
			"required": ["identifier"],
			"properties": {
				"identifier": {
					"type": "string",
					"$ref": "../../../../vanilla/definition/identifier.json"
				}
			}
		},
		"rule": {
			"title": "Rule",
			"type": "object",
			"additionalProperties": false,
			"required": ["direction", "geometry_part"],
			"properties": {
				"direction": {
					"title": "Facing",
					"description": "Specifies the direction of the neighbor block to check for culling. This direction rotates with a block's Transform component.",
					"$ref": "#/$defs/cardinal_direction"
				},
				"geometry_part": {
					"$ref": "#/$defs/rule_geometry_part"
				}
			}
		},
		"rule_geometry_part": {
			"title": "Rule Geometry Part",
			"description": "Specifies the bone, cube, and face that the block will be culled. The cube and face fields are optional to allow culling a specific face. Omitting these fields will cull the whole bone.",
			"type": "object",
			"additionalProperties": false,
			"required": ["bone"],
			"properties": {
				"bone": {
					"type": "string",
					"description": "The name of the bone to cull. This is the only required field, and it will cull the entire bone if cube and face are not specified."
				},
				"cube": {
					"type": "integer",
					"minimum": 0
				},
				"face": {
					"title": "Facing",
					"$ref": "#/$defs/cardinal_direction"
				}
			}
		}
	}
}
