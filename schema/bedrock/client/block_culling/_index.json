{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/client/block_culling/_index.json",
	"type": "object",
	"title": "Block Culling",
	"required": ["format_version"],
	"properties": {
		"format_version": {
			"enum": ["1.20.60", "1.21.80"]
		}
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.20.60"]
					}
				}
			},
			"then": {
				"$ref": "./1.20.60/_index.json"
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.21.80"]
					}
				}
			},
			"then": {
				"$ref": "./1.21.80/_index.json"
			}
		}
	]
}
