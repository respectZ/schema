{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/client/entity/1.8.0/_index.json",
	"title": "Minecraft Bedrock Actor Resource Definition 1.8.0",
	"description": "Defines client entity and attachable visual resources for actors, including textures, geometry, materials, animations, and render controllers.",
	"type": "object",
	"additionalProperties": false,
	"required": ["format_version", "minecraft:client_entity"],
	"properties": {
		"format_version": {
			"type": "string",
			"const": "1.8.0"
		},
		"minecraft:client_entity": {
			"$ref": "#/$defs/client_entity"
		}
	},
	"$defs": {
		"client_entity": {
			"type": "object",
			"required": ["description"],
			"additionalProperties": false,
			"properties": {
				"description": {
					"$ref": "#/$defs/description"
				}
			}
		},
		"description": {
			"type": "object",
			"additionalProperties": false,
			"required": ["identifier"],
			"properties": {
				"identifier": {
					"type": "string"
				},
				"min_engine_version": {
					"anyOf": [
						{
							"$ref": "../../../../vanilla/definition/format_version.json"
						},
						{
							"enum": ["1.8.0", "1.10.0"]
						}
					]
				},
				"materials": {
					"type": "object",
					"minProperties": 1,
					"additionalProperties": {
						"$ref": "../../../../vanilla/client/identifiers.json#/$defs/material_identifier"
					}
				},
				"textures": {
					"type": "object",
					"minProperties": 1,
					"additionalProperties": {
						"$ref": "../../../../vanilla/client/paths.json#/$defs/texture_path"
					}
				},
				"geometry": {
					"type": "object",
					"minProperties": 1,
					"additionalProperties": {
						"$ref": "../../../../vanilla/client/identifiers.json#/$defs/geometry_identifier"
					}
				},
				"animations": {
					"type": "object",
					"minProperties": 1,
					"additionalProperties": {
						"$ref": "../../../../vanilla/client/identifiers.json#/$defs/animation_identifier"
					}
				},
				"particle_effects": {
					"type": "object",
					"minProperties": 1,
					"additionalProperties": {
						"$ref": "../../../../vanilla/client/identifiers.json#/$defs/particle_identifier"
					}
				},
				"particle_emitters": {
					"type": "object",
					"minProperties": 1,
					"additionalProperties": {
						"$ref": "../../../../vanilla/client/identifiers.json#/$defs/particle_identifier"
					}
				},
				"sound_effects": {
					"type": "object",
					"minProperties": 1,
					"additionalProperties": {
						"$ref": "../../../../vanilla/client/identifiers.json#/$defs/sound_identifier"
					}
				},
				"animation_controllers": {
					"oneOf": [
						{
							"type": "array",
							"minItems": 1,
							"items": {
								"$ref": "../../../../vanilla/client/identifiers.json#/$defs/animation_controller_identifier"
							}
						},
						{
							"type": "array",
							"minItems": 1,
							"items": {
								"type": "object",
								"minProperties": 1,
								"additionalProperties": {
									"$ref": "../../../../vanilla/client/identifiers.json#/$defs/animation_controller_identifier"
								}
							}
						}
					]
				},
				"render_controllers": {
					"type": "array",
					"minProperties": 1,
					"items": {
						"$ref": "../../../../vanilla/client/identifiers.json#/$defs/render_controller_identifier"
					}
				},
				"scripts": {
					"$ref": "#/$defs/scripts"
				},
				"spawn_egg": {
					"$ref": "#/$defs/spawn_egg"
				},
				"enable_attachables": {
					"type": "boolean"
				},
				"held_item_ignores_lighting": {
					"type": "boolean"
				},
				"hide_armor": {
					"type": "boolean"
				}
			}
		},
		"scripts": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"pre_animation": {
					"type": "array",
					"minItems": 1,
					"items": {
						"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
					}
				},
				"scale": {
					"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
				},
				"scaleX": {
					"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
				},
				"scaleY": {
					"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
				},
				"scaleZ": {
					"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
				},
				"scalex": {
					"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
				},
				"scaley": {
					"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
				},
				"scalez": {
					"$ref": "../../../../vanilla/definition/molang.json#/$defs/string"
				}
			}
		},
		"spawn_egg": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"base_color": {
					"$ref": "#/$defs/color"
				},
				"overlay_color": {
					"$ref": "#/$defs/color"
				},
				"texture": {
					"$ref": "../../../../vanilla/client/identifiers.json#/$defs/item_texture_identifier"
				},
				"texture_index": {
					"type": "integer"
				}
			}
		},
		"color": {
			"type": "string",
			"description": "A hexadecimal color code in the format #RRGGBB.",
			"pattern": "^#([0-9a-fA-F]{6})$"
		}
	}
}
