{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/client/particle/1.10.0/components/particle_motion_dynamic.json",
	"title": "minecraft:particle_motion_dynamic",
	"description": "Applies dynamic simulation forces to particles.",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"linear_acceleration": {
			"description": "Linear acceleration in blocks/sec^2.",
			"type": "array",
			"minItems": 3,
			"maxItems": 3,
			"items": {
				"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression"
			}
		},
		"linear_drag_coefficient": {
			"description": "Linear drag coefficient.",
			"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression",
			"default": 0
		},
		"rotation_acceleration": {
			"description": "Rotation acceleration in degrees/sec^2.",
			"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression",
			"default": 0
		},
		"rotation_drag_coefficient": {
			"description": "Rotation drag coefficient.",
			"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression",
			"default": 0
		}
	}
}
