{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/client/particle/1.10.0/components/emitter_shape_disc.json",
	"title": "minecraft:emitter_shape_disc",
	"description": "Spawns particles using a disc shape.",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"plane_normal": {
			"description": "Disc plane normal.",
			"oneOf": [
				{
					"enum": ["x", "y", "z"]
				},
				{
					"type": "array",
					"minItems": 3,
					"maxItems": 3,
					"items": {
						"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression"
					}
				}
			]
		},
		"offset": {
			"description": "Offset from the emitter.",
			"type": "array",
			"minItems": 3,
			"maxItems": 3,
			"default": [0, 0, 0],
			"items": {
				"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression"
			}
		},
		"radius": {
			"description": "Disc radius.",
			"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression",
			"default": 1
		},
		"surface_only": {
			"description": "Emit only from the disc edge.",
			"type": "boolean",
			"default": false
		},
		"direction": {
			"description": "Particle emission direction.",
			"oneOf": [
				{
					"enum": ["inwards", "outwards"]
				},
				{
					"type": "array",
					"minItems": 3,
					"maxItems": 3,
					"items": {
						"$ref": "../../../../../vanilla/definition/molang.json#/$defs/expression"
					}
				}
			]
		}
	}
}
