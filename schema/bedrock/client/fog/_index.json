{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/client/fog/_index.json",
	"type": "object",
	"title": "Minecraft Bedrock Fog Settings",
	"required": ["format_version"],
	"properties": {
		"format_version": {
			"enum": ["1.16.100", "1.21.90"]
		}
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.16.100"]
					}
				}
			},
			"then": {
				"$ref": "./1.16.100/_index.json"
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.21.90"]
					}
				}
			},
			"then": {
				"$ref": "./1.21.90/_index.json"
			}
		}
	]
}
