				"type": "object",
				"additionalProperties": false,
				"properties": {
					"base": {
						"description": "Parent sound category to inherit sound settings from.",
						"$ref": "../../../vanilla/client/identifiers.json#/$defs/block_sound_identifier"
					},
					"events": {
						"type": "object",
						"description": "Sound events for this block type (break, place, step, hit, fall, etc.).",
						"additionalProperties": {
							"$ref": "#/$defs/sound_event"
						}
					},
					"pitch": {
						"description": "Pitch multiplier for block sounds. Can be a single value or a range [min, max].",
						"$ref": "#/$defs/float_range"
					},
					"volume": {
						"description": "Volume multiplier for block sounds.",
						"$ref": "#/$defs/float_range"
					}
				}
			}
		},
