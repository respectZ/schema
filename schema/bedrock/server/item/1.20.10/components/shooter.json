{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/item/1.20.10/components/shooter.json",
	"type": "object",
	"title": "Shooter",
	"description": "Shooter item component",
	"additionalProperties": false,
	"properties": {
		"ammunition": {
			"type": "array",
			"description": "Ammunition items",
			"items": {
				"type": "object",
				"title": "Ammunition",
				"additionalProperties": false,
				"required": ["item"],
				"properties": {
					"item": {
						"$ref": "../../../../../vanilla/server/identifiers.json#/$defs/item_identifier",
						"description": "Ammunition item identifier"
					},
					"use_in_creative": {
						"type": "boolean",
						"description": "Whether this ammunition can be used in creative mode",
						"default": false
					},
					"search_inventory": {
						"type": "boolean",
						"description": "Whether to search inventory for ammunition",
						"default": true
					}
				}
			}
		},
		"charge_on_draw": {
			"type": "boolean",
			"description": "Charge on draw",
			"default": false
		},
		"max_draw_duration": {
			"type": "number",
			"minimum": 0,
			"description": "Draw duration",
			"default": 0
		},
		"scale_power_by_draw_duration": {
			"type": "boolean",
			"description": "Scale power by draw duration",
			"default": false
		}
	}
}
