{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/item/_index.json",
	"type": "object",
	"title": "Item",
	"description": "Item definition file for behavior packs",
	"properties": {
		"format_version": {
			"enum": ["1.12.0", "1.20.0"]
		}
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.12.0"]
					}
				}
			},
			"then": {
				"$ref": "./1.12.0/_index.json"
			}
		},
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.20.0"]
					}
				}
			},
			"then": {
				"$ref": "./1.20.0/_index.json"
			}
		}
	]
}
