{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/dimension/_index.json",
	"type": "object",
	"title": "Minecraft Bedrock Dimension File",
	"description": "Schema for custom dimension definition files used by behavior packs.",
	"required": ["format_version"],
	"properties": {
		"format_version": {
			"enum": ["1.18.0"]
		}
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.18.0"]
					}
				}
			},
			"then": {
				"$ref": "./1.18.0/_index.json"
			}
		}
	]
}
