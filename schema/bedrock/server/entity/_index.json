{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/entity/_index.json",
	"type": "object",
	"title": "Minecraft Bedrock Entity File",
	"description": "Schema for entity behavior definition files used by behavior packs.",
	"required": ["format_version"],
	"properties": {
		"format_version": {
			"enum": ["1.8.0"]
		}
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"const": "1.8.0"
					}
				}
			},
			"then": {
				"$ref": "./1.8.0/_index.json"
			}
		}
	]
}
