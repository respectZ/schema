{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/entity/1.8.0/behavior/follow_caravan.json",
	"type": "object",
	"title": "Behavior Follow Caravan",
	"description": "Allows the mob to follow mobs that are in a caravan.",
	"additionalProperties": false,
	"properties": {
		"entity_count": {
			"type": "integer",
			"default": 1,
			"description": "Number of entities to follow in the caravan."
		},
		"entity_types": {
			"$ref": "../entity_types.json",
			"description": "Entity types to follow."
		},
		"speed_multiplier": {
			"type": "number",
			"default": 1.0,
			"description": "Movement speed multiplier while following."
		}
	}
}
