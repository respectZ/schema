{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/worldgen/structure_set/_index.json",
	"type": "object",
	"title": "Structure Set",
	"description": "A Jigsaw Structure Set is a collection of Jigsaw Structures that are placed according to a set of rules.",
	"properties": {
		"format_version": {
			"enum": ["1.21.20"]
		}
	},
	"oneOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"const": "1.21.20"
					}
				}
			},
			"then": {
				"$ref": "./1.21.20/_index.json"
			}
		}
	]
}
