{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/worldgen/template_pool/_index.json",
	"type": "object",
	"title": "Template Pool",
	"description": "Used to pair block rules with Structure Templates and to randomly place Structure Templates using a weighted list.",
	"properties": {
		"format_version": {
			"enum": ["1.21.20"]
		}
	},
	"oneOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"const": "1.21.20"
					}
				}
			},
			"then": {
				"$ref": "./1.21.20/_index.json"
			}
		}
	]
}
