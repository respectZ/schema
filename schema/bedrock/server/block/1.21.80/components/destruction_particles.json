{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/block/1.21.80/components/destruction_particles.json",
	"type": "object",
	"title": "Destruction Particles Component",
	"description": "Sets the particles that will be used when block is destroyed.",
	"additionalProperties": false,
	"properties": {
		"particle_count": {
			"type": "integer",
			"description": "Number of particles to spawn of destruction.",
			"default": 100,
			"maximum": 255
		},
		"texture": {
			"$ref": "../../../../../vanilla/client/identifiers.json#/$defs/terrain_texture_identifier",
			"description": "The texture name used for the particle."
		},
		"tint_method": {
			"type": "string",
			"description": "Tint multiplied to the color.",
			"default": "none",
			"enum": [
				"none",
				"default_foliage",
				"birch_foliage",
				"evergreen_foliage",
				"dry_foliage",
				"grass",
				"water"
			]
		}
	}
}
