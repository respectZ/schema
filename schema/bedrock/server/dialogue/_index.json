{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/dialogue/_index.json",
	"type": "object",
	"title": "Minecraft Bedrock NPC Dialogue File",
	"description": "Schema for NPC dialogue definition files used by behavior packs.",
	"required": ["format_version"],
	"properties": {
		"format_version": {
			"enum": ["1.14.0"]
		}
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.14.0"]
					}
				}
			},
			"then": {
				"$ref": "./1.14.0/_index.json"
			}
		}
	]
}
