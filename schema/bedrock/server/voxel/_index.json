{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/bedrock/server/voxel/_index.json",
	"type": "object",
	"title": "Minecraft Bedrock Voxel Shape File",
	"description": "Schema for voxel shape definition files used by behavior packs.",
	"required": ["format_version"],
	"properties": {
		"format_version": {
			"enum": ["1.21.110"]
		}
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"format_version": {
						"enum": ["1.21.110"]
					}
				}
			},
			"then": {
				"$ref": "./1.21.110/_index.json"
			}
		}
	]
}
