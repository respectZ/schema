{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/vanilla/server/filter/entity/filters/is_biome.json",
	"type": "object",
	"title": "Is Biome Filter",
	"description": "Tests whether the Subject is currently in the named biome.",
	"properties": {
		"test": true,
		"subject": true,
		"operator": true,
		"value": {
			"type": "string",
			"enum": [
				"beach",
				"desert",
				"extreme_hills",
				"flat",
				"forest",
				"ice",
				"jungle",
				"mesa",
				"mushroom_island",
				"ocean",
				"plain",
				"river",
				"savanna",
				"stone_beach",
				"swamp",
				"taiga",
				"the_end",
				"the_nether"
			]
		}
	},
	"required": ["value"]
}
