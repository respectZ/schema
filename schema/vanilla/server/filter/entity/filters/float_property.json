{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/vanilla/server/filter/entity/filters/float_property.json",
	"type": "object",
	"title": "Float Property Filter",
	"description": "Returns true when the float actor property matches the value provided.",
	"properties": {
		"test": true,
		"subject": true,
		"operator": true,
		"domain": {
			"type": "string",
			"description": "The property name to look for."
		},
		"value": {
			"type": "number",
			"description": "A floating point value."
		}
	},
	"required": ["domain", "value"]
}
