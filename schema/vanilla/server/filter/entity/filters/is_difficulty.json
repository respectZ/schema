{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/vanilla/server/filter/entity/filters/is_difficulty.json",
	"type": "object",
	"title": "Is Difficulty Filter",
	"description": "Tests the current difficulty level of the game.",
	"properties": {
		"test": true,
		"subject": true,
		"operator": true,
		"value": {
			"description": "The difficulty level to test.",
			"oneOf": [
				{
					"const": "peaceful",
					"description": "Peaceful difficulty."
				},
				{
					"const": "easy",
					"description": "Easy difficulty."
				},
				{
					"const": "normal",
					"description": "Normal difficulty."
				},
				{
					"const": "hard",
					"description": "Hard difficulty."
				}
			]
		}
	},
	"required": ["value"]
}
