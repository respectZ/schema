{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "schema/vanilla/server/filter/entity/filters/is_temperature_type.json",
	"type": "object",
	"title": "Is Temperature Type Filter",
	"description": "Tests whether the current temperature is a given type.",
	"properties": {
		"test": true,
		"subject": true,
		"operator": true,
		"value": {
			"description": "The temperature type to test.",
			"oneOf": [
				{
					"const": "cold",
					"description": "Cold temperature type."
				},
				{
					"const": "mild",
					"description": "Mild temperature type."
				},
				{
					"const": "warm",
					"description": "Warm temperature type."
				},
				{
					"const": "ocean",
					"description": "Ocean temperature type."
				}
			]
		}
	},
	"required": ["value"]
}
